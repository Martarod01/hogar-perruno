---
import { testimonials } from "../config/site";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section testimonials" id="testimonios" aria-labelledby="testimonials-title">
  <div class="wrap">
    <SectionHeading eyebrow={testimonials.eyebrow} title={testimonials.title} lead={testimonials.lead} id="testimonials-title" />

    <div class="testimonials__grid">
      {testimonials.items.map((item, i) => (
        <blockquote class="testimonials__card" data-reveal style={`--delay: ${i * 100}ms`}>
          <p class="testimonials__quote">{item.quote}</p>
          <footer class="testimonials__footer">
            <strong class="testimonials__author">{item.author}</strong>
            <span class="testimonials__dog">con {item.dog}</span>
            <span class="testimonials__tag">{item.detail}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--hp-sage-light);
  }

  .testimonials__grid {
    display: grid;
    gap: 18px;
  }

  .testimonials__card {
    margin: 0;
    padding: 28px 26px;
    border-radius: var(--radius-lg);
    background: #ffffff;
    border: 1px solid rgba(61, 52, 44, 0.12);
    box-shadow: 0 10px 28px -18px rgba(61, 52, 44, 0.2);
    display: grid;
    gap: 20px;
  }

  .testimonials__quote {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.08rem, 2vw, 1.22rem);
    font-weight: 500;
    font-style: normal;
    line-height: 1.65;
    color: #2c241e;
  }

  .testimonials__quote::before {
    content: "“";
    color: var(--hp-olive);
    font-size: 1.4em;
    line-height: 0;
    margin-right: 2px;
  }

  .testimonials__quote::after {
    content: "”";
    color: var(--hp-olive);
    font-size: 1.4em;
    line-height: 0;
    margin-left: 2px;
  }

  .testimonials__footer {
    display: grid;
    gap: 4px;
    padding-top: 16px;
    border-top: 1px solid rgba(61, 52, 44, 0.1);
  }

  .testimonials__author {
    color: #2c241e;
    font-size: 1rem;
    font-weight: 800;
  }

  .testimonials__dog {
    color: #5a5048;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .testimonials__tag {
    margin-top: 6px;
    width: fit-content;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    background: var(--hp-olive-soft);
    color: var(--hp-olive-dark);
    font-size: 0.75rem;
    font-weight: 700;
  }

  @media (min-width: 800px) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
