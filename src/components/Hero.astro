---
import { contact, hero, heroStats } from "../config/site";
import { siteImages } from "../config/images";
import SeoImage from "./SeoImage.astro";

const heroImage = siteImages.hero;
---

<section class="hero" id="inicio" aria-labelledby="hero-title">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow" data-reveal>{hero.eyebrow}</p>
      <div class="hero-headline" data-reveal style="--reveal-delay: 80ms">
        <h1 id="hero-title">{hero.title}</h1>
        <p class="hero-subtitle">{hero.subtitle}</p>
      </div>
      <p class="lead" data-reveal style="--reveal-delay: 160ms">{hero.description}</p>

      <div class="hero-actions" data-reveal style="--reveal-delay: 240ms" aria-label="Acciones principales">
        <a class="button" href="#contacto">
          {hero.cta}
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
        </a>
        <a class="button button--ghost" href="#como-trabajamos">{hero.secondaryCta}</a>
      </div>

      <ul class="hero-badges" data-reveal style="--reveal-delay: 320ms" aria-label="Ventajas de Hogar Perruno">
        {hero.badges.map((badge) => (
          <li>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7" /></svg>
            {badge}
          </li>
        ))}
      </ul>

      <dl class="hero-stats" data-reveal style="--reveal-delay: 400ms">
        {heroStats.map((stat) => (
          <div>
            <dt>{stat.value}</dt>
            <dd>{stat.label}</dd>
          </div>
        ))}
      </dl>

      <div class="hero-phones" data-reveal style="--reveal-delay: 480ms">
        <a href={`tel:${contact.phone1Href}`} class="phone-link">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 3h3l1.5 4.5L9 9a12 12 0 0 0 6 6l1.5-2.1 4.5 1.5v3a2 2 0 0 1-2.2 2A17 17 0 0 1 4.6 5.2 2 2 0 0 1 6.6 3Z" /></svg>
          {contact.phone1}
        </a>
        <a href={contact.whatsapp} target="_blank" rel="noreferrer" class="phone-link phone-link--wa">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 12a8 8 0 0 1-11.8 7L4 20l1.1-4A8 8 0 1 1 20 12Z" /><path d="M8.5 9.5c0 4 2 6 6 6" /></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <div class="hero-media" data-reveal style="--reveal-delay: 180ms">
      <figure class="hero-photo">
        <SeoImage
          image={heroImage.image}
          alt={heroImage.alt}
          title={heroImage.title}
          loading={heroImage.loading}
          fetchPriority={heroImage.fetchPriority}
          sizes="(min-width: 980px) 420px, 88vw"
          class="hero-photo__img"
        />
        <figcaption class="hero-photo-badge">
          <span class="hero-photo-name">Hogar Perruno</span>
          <span class="hero-photo-role">Las Rozas de Madrid</span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<script>
  const syncHeroPhoto = () => {
    const copy = document.querySelector(".hero-copy");
    const photo = document.querySelector(".hero-photo") as HTMLElement | null;
    if (!(copy instanceof HTMLElement) || !photo) return;
    const desktop = window.matchMedia("(min-width: 980px)").matches;
    if (desktop) {
      const height = copy.offsetHeight;
      photo.style.height = `${height}px`;
    } else {
      photo.style.height = "";
    }
  };

  const copy = document.querySelector(".hero-copy");
  if (copy) {
    syncHeroPhoto();
    window.addEventListener("resize", syncHeroPhoto, { passive: true });
    window.addEventListener("load", syncHeroPhoto);
    document.fonts?.ready.then(syncHeroPhoto);
    new ResizeObserver(syncHeroPhoto).observe(copy);
  }

  // Scroll reveal
  const reveals = document.querySelectorAll("[data-reveal]");
  const revealObserver = new IntersectionObserver(
    (entries) => entries.forEach((e) => e.isIntersecting && e.target.classList.add("is-visible")),
    { threshold: 0.1 }
  );
  reveals.forEach((el) => revealObserver.observe(el));
</script>

<style>
  .hero {
    position: relative;
    padding: clamp(48px, 7vw, 92px) 0 clamp(72px, 10vw, 124px);
    overflow: hidden;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 40px;
    align-items: start;
  }

  .hero-copy {
    display: grid;
    gap: 22px;
  }

  .hero-headline {
    display: grid;
    gap: 12px;
  }

  .hero-headline h1 {
    max-width: 16ch;
  }

  .hero-subtitle {
    margin: 0;
    max-width: 28ch;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.85rem);
    font-weight: 400;
    font-style: italic;
    line-height: 1.3;
    opacity: 0.85;
  }

  .hero-copy .lead {
    max-width: 44ch;
  }

  .hero-actions {
    display: grid;
    gap: 12px;
    margin-top: 4px;
  }

  .hero-actions .button svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 240ms var(--ease);
  }

  .hero-actions .button:hover svg {
    transform: translateX(3px);
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    margin: 4px 0 0;
    list-style: none;
  }

  .hero-badges li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 15px;
    border: 1px solid rgba(90, 122, 82, 0.22);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-charcoal);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .hero-badges svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: var(--color-green);
    stroke-width: 2.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(12px, 3vw, 34px);
    width: 100%;
    max-width: 470px;
    margin: 14px 0 0;
    padding-top: 26px;
    border-top: 1px solid var(--color-line);
  }

  .hero-stats dt {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.8vw, 2.2rem);
    font-weight: 600;
    color: var(--color-green-dark);
    line-height: 1;
  }

  .hero-stats dd {
    margin: 8px 0 0;
    color: var(--color-graphite);
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.35;
  }

  .hero-phones {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .phone-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    background: var(--color-white);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    color: var(--color-ink);
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 220ms var(--ease), border-color 220ms var(--ease), box-shadow 220ms var(--ease);
  }

  .phone-link:hover,
  .phone-link:focus-visible {
    transform: translateY(-2px);
    border-color: rgba(90, 122, 82, 0.4);
    box-shadow: var(--shadow-card);
    color: var(--color-green-dark);
  }

  .phone-link--wa {
    background: var(--color-green-soft);
    border-color: rgba(90, 122, 82, 0.25);
    color: var(--color-green-dark);
  }

  .phone-link svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  .hero-media {
    position: relative;
    width: 100%;
  }

  .hero-media::before {
    position: absolute;
    inset: 18px -18px -18px 18px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(90, 122, 82, 0.18), rgba(139, 99, 71, 0.12));
    content: "";
  }

  .hero-photo {
    position: relative;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 3 / 4;
    box-shadow: var(--shadow-float);
  }

  .hero-photo :global(.hero-photo__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .hero-photo-badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    display: grid;
    gap: 2px;
    padding: 12px 18px;
    border-radius: var(--radius-pill);
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: var(--shadow-card);
  }

  .hero-photo-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.1;
  }

  .hero-photo-role {
    color: var(--color-green-dark);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 56px;
      align-items: start;
    }

    .hero-media {
      width: auto;
      justify-self: end;
      align-self: start;
    }

    .hero-photo {
      aspect-ratio: auto;
    }
  }

  @media (min-width: 520px) {
    .hero-actions {
      display: flex;
      flex-wrap: wrap;
    }
  }
</style>
