---
import { contact, footer, local, navItems, seo } from "../config/site";

const year = new Date().getFullYear();
const hasInstagram = Boolean(contact.instagram);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={seo.logo} alt="Hogar Perruno" width="400" height="400" loading="lazy" />
      <p>{footer.tagline}</p>
      <p class="footer-nap">
        Alojamiento canino en {local.city} ·
        <a href={`tel:${contact.phone1Href}`}>{contact.phone1}</a>
      </p>
      {hasInstagram && (
        <div class="footer-social">
          <a href={contact.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram de Hogar Perruno">
            Instagram
          </a>
        </div>
      )}
    </div>

    <div class="footer-col">
      <h2>Navegación</h2>
      <nav class="footer-links" aria-label="Navegación secundaria">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </div>

    <div class="footer-col">
      <h2>Contacto</h2>
      <div class="footer-links">
        <a href={`tel:${contact.phone1Href}`}>{contact.phone1}</a>
        <a href={`tel:${contact.phone2Href}`}>{contact.phone2}</a>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
        <a href={contact.whatsapp} target="_blank" rel="noreferrer">WhatsApp</a>
      </div>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {year} Hogar Perruno. Todos los derechos reservados.</p>
    <nav class="footer-legal" aria-label="Enlaces legales">
      <a href="/aviso-legal/">Aviso legal</a>
      <a href="/privacidad/">Privacidad</a>
      <a href="/cookies/">Cookies</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    padding: clamp(52px, 7vw, 72px) 0 28px;
    background: var(--color-ink);
    color: rgba(255, 255, 255, 0.72);
  }

  .footer-grid {
    display: grid;
    gap: 40px;
  }

  .footer-brand img {
    width: 130px;
    height: auto;
    margin-bottom: 20px;
    padding: 10px 14px;
    border-radius: 14px;
    background: var(--color-white);
  }

  .footer-brand p {
    max-width: 420px;
    line-height: 1.7;
  }

  .footer-nap {
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.82rem;
  }

  .footer-nap a {
    color: var(--color-moss);
    font-weight: 600;
  }

  .footer-social {
    display: flex;
    gap: 12px;
    margin-top: 22px;
  }

  .footer-social a {
    padding: 9px 16px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-pill);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.82rem;
    font-weight: 600;
    transition: border-color 200ms var(--ease), color 200ms var(--ease), background-color 200ms var(--ease);
  }

  .footer-social a:hover,
  .footer-social a:focus-visible {
    border-color: var(--color-green);
    background: rgba(90, 122, 82, 0.14);
    color: var(--color-white);
  }

  h2 {
    margin: 0 0 18px;
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .footer-links {
    display: grid;
    gap: 12px;
  }

  .footer-links a {
    width: fit-content;
    color: rgba(255, 255, 255, 0.72);
    font-weight: 500;
    transition: color 180ms var(--ease), transform 180ms var(--ease);
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--color-moss);
    transform: translateX(3px);
  }

  .footer-bottom {
    display: grid;
    gap: 8px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-bottom a {
    color: var(--color-moss);
    font-weight: 600;
  }

  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
  }

  @media (min-width: 760px) {
    .footer-grid {
      grid-template-columns: minmax(0, 1.5fr) repeat(2, minmax(150px, 0.6fr));
    }

    .footer-bottom {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }
</style>
