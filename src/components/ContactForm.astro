---
import { contact } from "../config/site";

interface Props {
  title?: string;
  description?: string;
  googleScriptEndpoint?: string;
}

const {
  title = "Solicita información o reserva",
  description = "Cuéntanos cómo es tu perro y te contactamos para organizar la estancia.",
  googleScriptEndpoint = "",
} = Astro.props;
---

<form class="form" data-contact-form data-endpoint={googleScriptEndpoint}>
  <div class="form__head">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>

  <input type="text" name="_gotcha" class="form__hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <input type="hidden" name="source" value="Hogar Perruno (contacto)" />

  <div class="form__row">
    <label>
      <span>Tu nombre</span>
      <input type="text" name="name" autocomplete="name" required />
    </label>
    <label>
      <span>Teléfono</span>
      <input type="tel" name="phone" autocomplete="tel" required />
    </label>
  </div>

  <label>
    <span>Email</span>
    <input type="email" name="email" autocomplete="email" required />
  </label>

  <div class="form__row form__row--dog">
    <label>
      <span>Nombre del perro</span>
      <input type="text" name="dog_name" />
    </label>
    <label>
      <span>Raza</span>
      <input type="text" name="dog_breed" />
    </label>
    <label>
      <span>Edad</span>
      <input type="text" name="dog_age" placeholder="Ej. 3 años" />
    </label>
  </div>

  <div class="form__row">
    <label>
      <span>Fecha entrada</span>
      <input type="date" name="date_from" />
    </label>
    <label>
      <span>Fecha salida</span>
      <input type="date" name="date_to" />
    </label>
  </div>

  <label>
    <span>Comentarios</span>
    <textarea name="message" rows="4" placeholder="Rutina, alimentación, medicación, personalidad..."></textarea>
  </label>

  <label class="form__consent">
    <input type="checkbox" name="consent" value="accepted" required />
    <span>
      Acepto la <a href="/privacidad/" target="_blank" rel="noreferrer">política de privacidad</a>
      y autorizo a Hogar Perruno a contactarme.
    </span>
  </label>

  <button class="btn form__submit" type="submit" data-submit>Enviar solicitud</button>
  <p class="form__status" aria-live="polite" data-status></p>

  <p class="form__alt">
    ¿Prefieres WhatsApp?
    <a href={contact.whatsapp} target="_blank" rel="noreferrer">Escríbenos aquí</a>
  </p>
</form>

<script>
  document.querySelectorAll("[data-contact-form]").forEach((form) => {
    const status = form.querySelector("[data-status]");
    const button = form.querySelector("[data-submit]");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!(form instanceof HTMLFormElement) || !(status instanceof HTMLElement)) return;

      const hp = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
      if (hp?.value) return;

      const endpoint = form.dataset.endpoint;
      if (button instanceof HTMLButtonElement) {
        button.disabled = true;
        button.textContent = "Enviando…";
      }

      try {
        if (endpoint) {
          const params = new URLSearchParams();
          for (const [key, value] of new FormData(form)) {
            if (key === "_gotcha") continue;
            params.append(key, String(value));
          }

          await fetch(endpoint, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: params.toString(),
          });
        } else {
          throw new Error("missing endpoint");
        }
        status.textContent = "¡Mensaje enviado! Te contactamos pronto.";
        status.className = "form__status form__status--ok";
        form.reset();
      } catch {
        status.textContent = "Error al enviar. Prueba por WhatsApp o teléfono.";
        status.className = "form__status form__status--err";
      } finally {
        if (button instanceof HTMLButtonElement) {
          button.disabled = false;
          button.textContent = "Enviar solicitud";
        }
      }
    });
  });
</script>

<style>
  .form { display: grid; gap: 14px; }
  .form__hp { position: absolute; opacity: 0; pointer-events: none; }

  .form__head h3 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 600;
  }

  .form__head p {
    margin: 6px 0 0;
    color: var(--hp-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .form__row {
    display: grid;
    gap: 12px;
  }

  label { display: grid; gap: 6px; }
  label span { font-size: 0.8rem; font-weight: 600; color: var(--hp-ink); }

  input, textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--hp-sand);
    border-radius: 12px;
    background: var(--hp-cream);
    color: var(--hp-ink);
    transition: border-color 180ms, box-shadow 180ms;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: var(--hp-olive);
    box-shadow: 0 0 0 3px rgba(95, 122, 86, 0.15);
  }

  textarea { resize: vertical; min-height: 100px; }

  .form__consent {
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .form__consent input { width: 18px; height: 18px; margin-top: 2px; accent-color: var(--hp-olive); }
  .form__consent span { font-size: 0.8rem; color: var(--hp-muted); line-height: 1.5; font-weight: 400; }
  .form__consent a { color: var(--hp-olive-dark); font-weight: 700; }

  .form__submit { width: 100%; }

  .form__status { margin: 0; font-size: 0.86rem; font-weight: 600; min-height: 1.2em; }
  .form__status--ok { color: #3d7a4b; }
  .form__status--err { color: #b33; }

  .form__alt {
    margin: 4px 0 0;
    font-size: 0.85rem;
    color: var(--hp-muted);
    text-align: center;
  }

  .form__alt a { color: var(--hp-olive-dark); font-weight: 700; }

  @media (min-width: 520px) {
    .form__row { grid-template-columns: 1fr 1fr; }
    .form__row--dog { grid-template-columns: 1fr 1fr 1fr; }
  }
</style>
