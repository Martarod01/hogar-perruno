---
import { contact } from "../config/site";

interface Props {
  variant?: "hero" | "footer";
  title?: string;
  description?: string;
  googleScriptEndpoint?: string;
}

const {
  variant = "hero",
  title = "Solicita información o reserva",
  description = "Cuéntanos cómo es tu perro y te contactamos para organizar la estancia.",
  googleScriptEndpoint = "",
} = Astro.props;

const formId = `contact-form-${variant}`;
---

<form
  class={`contact-form contact-form--${variant}`}
  id={formId}
  data-contact-form
  data-endpoint={googleScriptEndpoint}
  data-variant={variant}
>
  <div class="form-heading">
    <p class="eyebrow">Contacto</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <input type="text" name="_gotcha" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
  <input type="hidden" name="source" value={`Hogar Perruno (${variant})`} />

  <div class="field-grid">
    <label>
      <span>Tu nombre</span>
      <input type="text" name="name" autocomplete="name" placeholder="Tu nombre" required />
    </label>
    <label>
      <span>Teléfono</span>
      <input type="tel" name="phone" autocomplete="tel" placeholder="Tu teléfono" required />
    </label>
  </div>

  <label>
    <span>Email</span>
    <input type="email" name="email" autocomplete="email" placeholder="tu@email.com" required />
  </label>

  <div class="field-grid">
    <label>
      <span>Nombre del perro</span>
      <input type="text" name="dog_name" placeholder="¿Cómo se llama?" />
    </label>
    <label>
      <span>Raza</span>
      <input type="text" name="dog_breed" placeholder="Raza o tipo de perro" />
    </label>
  </div>

  <div class="field-grid">
    <label>
      <span>Fecha de entrada</span>
      <input type="date" name="date_from" />
    </label>
    <label>
      <span>Fecha de salida</span>
      <input type="date" name="date_to" />
    </label>
  </div>

  <label>
    <span>Necesidades especiales o comentarios</span>
    <textarea name="message" rows="4" placeholder="Rutina, alimentación, medicación, personalidad... cuéntanos lo que necesitamos saber para cuidarle bien"></textarea>
  </label>

  <label class="consent">
    <input type="checkbox" name="consent" value="accepted" required />
    <span>
      He leído y acepto la <a href="/privacidad/" target="_blank" rel="noreferrer">política de privacidad</a>
      y autorizo a Hogar Perruno a contactarme para responder a mi solicitud.
    </span>
  </label>

  <button class="button" type="submit" data-submit-button>
    Enviar solicitud
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h15m-6-6 6 6-6 6" /></svg>
  </button>

  <p class="form-status" aria-live="polite" data-form-status></p>

  <div class="form-alternative">
    <span>¿Prefieres escribirnos directamente?</span>
    <a href={contact.whatsapp} target="_blank" rel="noreferrer" class="wa-link">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 12a8 8 0 0 1-11.8 7L4 20l1.1-4A8 8 0 1 1 20 12Z" /><path d="M8.5 9.5c0 4 2 6 6 6" /></svg>
      WhatsApp
    </a>
  </div>
</form>

<script>
  document.querySelectorAll("[data-contact-form]").forEach((form) => {
    const status = form.querySelector("[data-form-status]");
    const button = form.querySelector("[data-submit-button]");
    const endpoint = (form as HTMLFormElement).dataset.endpoint;

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!(form instanceof HTMLFormElement)) return;
      if (!(status instanceof HTMLElement)) return;

      const honeypot = form.querySelector<HTMLInputElement>('[name="_gotcha"]');
      if (honeypot?.value) return;

      if (button instanceof HTMLButtonElement) {
        button.disabled = true;
        button.textContent = "Enviando…";
      }

      status.textContent = "";
      status.className = "form-status";

      try {
        if (endpoint) {
          const data = new FormData(form);
          await fetch(endpoint, { method: "POST", body: data, mode: "no-cors" });
        }

        status.textContent = "¡Mensaje enviado! Te contactamos lo antes posible.";
        status.classList.add("form-status--ok");
        form.reset();
      } catch {
        status.textContent = "Algo no ha ido bien. Escríbenos directamente por WhatsApp o teléfono.";
        status.classList.add("form-status--error");
      } finally {
        if (button instanceof HTMLButtonElement) {
          button.disabled = false;
          button.innerHTML = `Enviar solicitud <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h15m-6-6 6 6-6 6" /></svg>`;
        }
      }
    });
  });
</script>

<style>
  .honeypot {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }

  .contact-form {
    display: grid;
    gap: 18px;
  }

  .form-heading {
    display: grid;
    gap: 10px;
  }

  .form-heading .eyebrow { margin-bottom: 0; }

  .form-heading h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
  }

  .form-heading p {
    color: var(--color-graphite);
    font-size: 0.96rem;
    line-height: 1.6;
  }

  .field-grid {
    display: grid;
    gap: 14px;
  }

  label {
    display: grid;
    gap: 7px;
  }

  label span {
    color: var(--color-ink);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  input,
  textarea,
  select {
    width: 100%;
    padding: 13px 16px;
    border: 1.5px solid var(--color-sand);
    border-radius: var(--radius-sm);
    background: var(--color-white);
    color: var(--color-ink);
    font-size: 0.97rem;
    transition: border-color 180ms var(--ease), box-shadow 180ms var(--ease);
    appearance: none;
  }

  input:focus,
  textarea:focus,
  select:focus {
    outline: none;
    border-color: var(--color-green);
    box-shadow: 0 0 0 3px rgba(90, 122, 82, 0.14);
  }

  input[type="date"] {
    cursor: pointer;
  }

  textarea { resize: vertical; min-height: 110px; }

  .consent {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    padding: 0;
    flex-shrink: 0;
    margin-top: 2px;
    border-radius: 5px;
    accent-color: var(--color-green);
    cursor: pointer;
  }

  .consent span {
    font-size: 0.82rem;
    color: var(--color-graphite);
    line-height: 1.6;
    font-weight: 400;
  }

  .consent a {
    color: var(--color-green-dark);
    font-weight: 700;
  }

  .button {
    width: 100%;
    justify-content: center;
  }

  .button svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 240ms var(--ease);
  }

  .button:hover svg { transform: translateX(3px); }

  .form-status {
    font-size: 0.88rem;
    font-weight: 600;
    min-height: 1.4em;
  }

  .form-status--ok { color: var(--color-success); }
  .form-status--error { color: #c0392b; }

  .form-alternative {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding-top: 8px;
    border-top: 1px solid var(--color-line);
    font-size: 0.85rem;
    color: var(--color-graphite);
  }

  .wa-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    background: var(--color-green-soft);
    color: var(--color-green-dark);
    font-weight: 700;
    font-size: 0.85rem;
    transition: background-color 180ms var(--ease), transform 180ms var(--ease);
  }

  .wa-link:hover {
    background: var(--color-green);
    color: var(--color-white);
    transform: translateY(-1px);
  }

  .wa-link svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (min-width: 540px) {
    .field-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
