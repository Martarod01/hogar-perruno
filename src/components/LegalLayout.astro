---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  pageTitle: string;
}

const { eyebrow, title, description, pageTitle } = Astro.props;
---

<BaseLayout title={pageTitle} description={description}>
  <section class="section legal-page">
    <div class="wrap legal-card" data-reveal>
      <p class="legal-card__eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <div class="legal-content">
        <slot />
      </div>
      <a class="btn" href="/">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-page {
    min-height: 72vh;
    background: var(--hp-cream);
  }

  .legal-card {
    display: grid;
    max-width: 820px;
    gap: 18px;
    padding: clamp(28px, 6vw, 52px);
    border-radius: var(--radius-lg);
    background: var(--hp-paper);
    box-shadow: var(--shadow);
  }

  .legal-card__eyebrow {
    margin: 0;
    color: var(--hp-olive);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.9rem, 6vw, 3rem);
    font-weight: 600;
  }

  .legal-content {
    display: grid;
    gap: 16px;
    color: var(--hp-muted);
  }

  .legal-content :global(h2) {
    margin-top: 12px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--hp-ink);
  }

  .legal-content :global(p),
  .legal-content :global(li) { line-height: 1.75; }

  .legal-content :global(ul) {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 1.2rem;
  }

  .legal-content :global(a) {
    color: var(--hp-olive-dark);
    font-weight: 700;
  }

  .legal-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .legal-content :global(th),
  .legal-content :global(td) {
    padding: 10px 12px;
    border: 1px solid var(--hp-line);
    text-align: left;
  }

  .legal-content :global(th) {
    background: var(--hp-olive-soft);
    color: var(--hp-ink);
  }

  .btn { width: fit-content; margin-top: 12px; }
</style>
