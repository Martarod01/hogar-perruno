---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  pageTitle: string;
}

const { eyebrow, title, description, pageTitle } = Astro.props;
---

<BaseLayout title={pageTitle} description={description}>
  <section class="section legal-page">
    <div class="container legal-card" data-reveal>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <div class="legal-content">
        <slot />
      </div>
      <a class="button" href="/">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-page {
    min-height: 72vh;
    background: var(--color-beige);
  }

  .legal-card {
    display: grid;
    max-width: 820px;
    gap: 18px;
    padding: clamp(28px, 6vw, 52px);
    border-radius: var(--radius-lg);
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
  }

  h1 { font-size: clamp(1.9rem, 6vw, 3.2rem); }

  .legal-content {
    display: grid;
    gap: 16px;
    color: var(--color-graphite);
  }

  .legal-content :global(h2) {
    margin-top: 12px;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--color-ink);
  }

  .legal-content :global(h3) {
    margin-top: 8px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-charcoal);
  }

  .legal-content :global(p),
  .legal-content :global(li) { line-height: 1.75; }

  .legal-content :global(ul) {
    display: grid;
    gap: 8px;
    margin: 0;
    padding-left: 1.2rem;
  }

  .legal-content :global(a) {
    color: var(--color-green-dark);
    font-weight: 700;
  }

  .legal-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .legal-content :global(th),
  .legal-content :global(td) {
    padding: 10px 12px;
    border: 1px solid var(--color-line);
    text-align: left;
    vertical-align: top;
  }

  .legal-content :global(th) {
    background: var(--color-cream);
    color: var(--color-ink);
    font-weight: 700;
  }

  .button {
    width: fit-content;
    margin-top: 12px;
  }
</style>
