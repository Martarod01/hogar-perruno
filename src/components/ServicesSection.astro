---
import { services } from "../config/site";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section services" id="servicios" aria-labelledby="services-title">
  <div class="wrap">
    <SectionHeading eyebrow={services.eyebrow} title={services.title} lead={services.lead} id="services-title" />

    <div class="services__grid">
      {services.items.map((service, i) => (
        <article class="services__card" data-reveal style={`--delay: ${(i % 3) * 70}ms`}>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services__grid {
    display: grid;
    gap: 18px;
    grid-template-columns: 1fr;
  }

  .services__card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 220px;
    padding: 28px 26px;
    border-radius: var(--radius-lg);
    background: linear-gradient(145deg, var(--hp-olive-soft), var(--hp-paper));
    border: 1px solid rgba(109, 143, 100, 0.12);
    box-shadow: 0 14px 36px -18px rgba(109, 143, 100, 0.28);
    overflow: hidden;
    transition:
      transform 280ms var(--ease),
      box-shadow 280ms var(--ease),
      border-color 280ms var(--ease);
  }

  .services__card:hover {
    transform: translateY(-5px);
    border-color: rgba(109, 143, 100, 0.28);
    box-shadow: 0 20px 44px -16px rgba(109, 143, 100, 0.38);
  }

  .services__card h3 {
    margin: 0 0 12px;
    font-family: var(--font-serif);
    font-size: 1.28rem;
    font-weight: 600;
    color: var(--hp-ink);
    line-height: 1.25;
  }

  .services__card p {
    margin: 0;
    color: var(--hp-muted);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .services__card {
      min-height: 240px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .services__card:hover {
      transform: none;
    }
  }
</style>
