---
import ContactForm from "./ContactForm.astro";
import { contact, contactSection } from "../config/site";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section contact" id="contacto" aria-labelledby="contact-title">
  <div class="wrap contact__grid">
    <div data-reveal>
      <SectionHeading
        eyebrow={contactSection.eyebrow}
        title={contactSection.title}
        lead={contactSection.lead}
        align="left"
        id="contact-title"
      />

      <div class="contact__channels">
        <a href={`tel:${contact.phone1Href}`}>
          <span>Teléfono</span>
          <strong>{contact.phone1}</strong>
        </a>
        <a href={`tel:${contact.phone2Href}`}>
          <span>Teléfono</span>
          <strong>{contact.phone2}</strong>
        </a>
        <a href={`mailto:${contact.email}`}>
          <span>Email</span>
          <strong>{contact.email}</strong>
        </a>
        <a href={contact.whatsapp} target="_blank" rel="noreferrer">
          <span>WhatsApp</span>
          <strong>Escríbenos directamente</strong>
        </a>
      </div>

      <p class="contact__location">Las Rozas de Madrid</p>
    </div>

    <div class="contact__form-wrap" data-reveal style="--delay: 100ms">
      <ContactForm
        title={contactSection.formTitle}
        description={contactSection.formDescription}
      />
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    gap: 36px;
    align-items: start;
  }

  .contact__channels {
    display: grid;
    gap: 10px;
    margin-top: 8px;
  }

  .contact__channels a {
    display: grid;
    gap: 2px;
    padding: 16px 18px;
    border-radius: var(--radius);
    background: var(--hp-paper);
    border: 1px solid var(--hp-line);
    transition: border-color 200ms, transform 200ms;
  }

  .contact__channels a:hover {
    border-color: var(--hp-olive);
    transform: translateX(4px);
  }

  .contact__channels span {
    font-size: 0.78rem;
    color: var(--hp-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .contact__channels strong {
    color: var(--hp-olive-dark);
    font-size: 0.95rem;
  }

  .contact__location {
    margin: 18px 0 0;
    color: var(--hp-muted);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .contact__form-wrap {
    padding: clamp(24px, 4vw, 36px);
    border-radius: var(--radius-xl);
    background: var(--hp-paper);
    border: 2px solid var(--hp-honey);
    box-shadow: var(--shadow);
  }

  @media (min-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr 1.05fr;
      gap: 48px;
    }
  }
</style>
