---
import { methodology } from "../config/site";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section section--alt process" id="como-trabajamos" aria-labelledby="process-title">
  <div class="wrap process__layout">
    <div data-reveal>
      <SectionHeading
        eyebrow={methodology.eyebrow}
        title={methodology.title}
        lead={methodology.lead}
        align="left"
        id="process-title"
      />
      <a class="btn" href="#contacto">{methodology.cta}</a>
    </div>

    <ol class="process__steps">
      {methodology.steps.map((step, i) => (
        <li data-reveal style={`--delay: ${i * 90}ms`}>
          <span class="process__step">{step.step}</span>
          <div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process__layout {
    display: grid;
    gap: 36px;
    align-items: start;
  }

  .process__steps {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 14px;
  }

  .process__steps li {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 16px;
    align-items: start;
    padding: 24px;
    border-radius: var(--radius-lg);
    background: var(--hp-paper);
    border: 1px solid var(--hp-honey);
    box-shadow: var(--shadow-soft);
  }

  .process__step {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--hp-olive), #85a67c);
    color: #fff;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    box-shadow: 0 8px 20px -8px rgba(109, 143, 100, 0.5);
  }

  .process__steps h3 {
    margin: 0 0 6px;
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
  }

  .process__steps p {
    margin: 0;
    color: var(--hp-muted);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  @media (min-width: 900px) {
    .process__layout {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 48px;
    }
  }
</style>
