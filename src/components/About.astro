---
import { about } from "../config/site";
import { siteImages } from "../config/images";
import SeoImage from "./SeoImage.astro";

const aboutImage = siteImages.about;
---

<section class="section section--soft about" id="sobre-nosotros" aria-labelledby="about-title">
  <div class="container about-grid">
    <div class="about-media" data-reveal>
      <figure class="about-photo">
        <SeoImage
          image={aboutImage.image}
          alt={aboutImage.alt}
          title={aboutImage.title}
          loading={aboutImage.loading}
          sizes="(min-width: 900px) 380px, 88vw"
          class="about-photo__img"
        />
        <figcaption class="about-photo-badge">
          <span class="about-photo-name">Hogar Perruno</span>
          <span class="about-photo-role">Las Rozas · Cuidadores de confianza</span>
        </figcaption>
      </figure>
    </div>

    <div class="about-content" data-reveal style="--reveal-delay: 100ms">
      <p class="eyebrow">{about.eyebrow}</p>
      <h2 id="about-title">{about.title}</h2>
      <div class="accent-line"></div>

      <div class="about-copy">
        {about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <p class="about-signature">{about.signature}</p>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    gap: 40px;
    align-items: start;
    overflow: visible;
  }

  .about-media {
    position: relative;
    width: min(100%, 380px);
    justify-self: center;
    padding: 0 18px 18px 0;
    overflow: visible;
  }

  .about-media::before {
    position: absolute;
    inset: 18px -18px -18px 18px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(90, 122, 82, 0.18), rgba(139, 99, 71, 0.1));
    content: "";
    z-index: 0;
  }

  .about-photo {
    position: relative;
    z-index: 1;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-float);
  }

  .about-photo :global(.about-photo__img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  .about-photo-badge {
    position: absolute;
    left: 16px;
    bottom: 16px;
    display: grid;
    gap: 2px;
    padding: 12px 18px;
    border-radius: var(--radius-pill);
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: var(--shadow-card);
  }

  .about-photo-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.1;
  }

  .about-photo-role {
    color: var(--color-green-dark);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .about-content {
    position: relative;
    display: grid;
    gap: 22px;
    padding: clamp(28px, 4vw, 40px);
    border-radius: var(--radius-lg);
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .about-copy {
    display: grid;
    gap: 18px;
    color: var(--color-graphite);
    font-size: clamp(1rem, 1.5vw, 1.08rem);
    line-height: 1.78;
  }

  .about-copy p:first-child {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.15rem, 2vw, 1.38rem);
    line-height: 1.5;
  }

  .about-signature {
    margin: 4px 0 0;
    color: var(--color-green-dark);
    font-weight: 700;
    font-size: 0.86rem;
    letter-spacing: 0.02em;
  }

  @media (min-width: 900px) {
    .about-grid {
      grid-template-columns: clamp(300px, 34vw, 400px) minmax(0, 1fr);
      gap: clamp(48px, 5vw, 72px);
      align-items: stretch;
    }

    .about-media {
      width: 100%;
      justify-self: stretch;
    }

    .about-photo { height: 100%; }

    .about-photo :global(.about-photo__img) {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }
  }
</style>
