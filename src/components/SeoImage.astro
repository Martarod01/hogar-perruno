---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  title?: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  fetchPriority?: "high" | "low" | "auto";
  class?: string;
  sizes?: string;
}

const {
  image,
  alt,
  title,
  width,
  height,
  loading = "lazy",
  fetchPriority,
  class: className,
  sizes = "(min-width: 980px) 50vw, 100vw",
} = Astro.props;
---

<Image
  src={image}
  alt={alt}
  title={title}
  width={width ?? image.width}
  height={height ?? image.height}
  loading={loading}
  fetchpriority={fetchPriority}
  decoding="async"
  sizes={sizes}
  class={className}
/>
