---
import { gallery } from "../config/site";
import { galleryImages } from "../config/images";
import SeoImage from "./SeoImage.astro";
import SectionHeading from "./SectionHeading.astro";
---

<section class="section gallery" id="galeria" aria-labelledby="gallery-title">
  <div class="wrap">
    <SectionHeading eyebrow={gallery.eyebrow} title={gallery.title} lead={gallery.lead} id="gallery-title" />

    <div class="gallery__grid">
      {galleryImages.map((item, i) => (
        <figure class={`gallery__item gallery__item--${item.span ?? "normal"}`} data-reveal style={`--delay: ${(i % 4) * 60}ms`}>
          <SeoImage
            image={item.image}
            alt={item.alt}
            title={item.title}
            loading="lazy"
            sizes="(min-width: 900px) 33vw, 100vw"
            class="gallery__img"
          />
          {item.caption && <figcaption>{item.caption}</figcaption>}
        </figure>
      ))}
    </div>

    <p class="gallery__note" data-reveal>
      Próximamente añadiremos fotos reales de nuestros huéspedes. Mientras tanto, esta galería muestra el tipo de momentos que compartimos cada día.
    </p>
  </div>
</section>

<style>
  .gallery__grid {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
  }

  .gallery__item {
    margin: 0;
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--hp-peach);
    border: 3px solid var(--hp-paper);
    box-shadow: var(--shadow-soft);
  }

  .gallery__item :global(.gallery__img) {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    transition: transform 400ms var(--ease);
  }

  .gallery__item:hover :global(.gallery__img) {
    transform: scale(1.04);
  }

  .gallery__item figcaption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 14px 16px;
    background: linear-gradient(transparent, rgba(31, 26, 22, 0.75));
    color: #fff;
    font-size: 0.82rem;
    font-weight: 500;
  }

  .gallery__note {
    margin: 28px auto 0;
    max-width: 560px;
    text-align: center;
    color: var(--hp-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  @media (min-width: 640px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }

    .gallery__item--wide { grid-column: span 2; }
    .gallery__item--tall { grid-row: span 2; }
  }

  @media (min-width: 960px) {
    .gallery__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 180px;
    }

    .gallery__item--wide { grid-column: span 2; }
  }
</style>
