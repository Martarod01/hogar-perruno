---
import { hero, heroStats, contact } from "../config/site";
import { siteImages } from "../config/images";
import SeoImage from "./SeoImage.astro";

const img = siteImages.hero;
---

<section class="hero" id="inicio">
  <div class="hero__media">
    <SeoImage
      image={img.image}
      alt={img.alt}
      title={img.title}
      loading={img.loading}
      fetchPriority={img.fetchPriority}
      sizes="100vw"
      class="hero__img"
    />
    <div class="hero__overlay"></div>
  </div>

  <div class="wrap hero__content">
    <div class="hero__card" data-reveal>
      <p class="hero__eyebrow">
        <span aria-hidden="true">🐾</span>
        {hero.eyebrow}
      </p>
      <h1 class="hero__title">{hero.title}</h1>
      <p class="hero__subtitle">{hero.subtitle}</p>
      <p class="hero__text">{hero.description}</p>

      <div class="hero__actions">
        <a class="btn" href="/#contacto">{hero.cta}</a>
        <a class="btn btn--outline" href="/#galeria">Ver galería</a>
      </div>
    </div>

    <aside class="hero__aside" data-reveal style="--delay: 120ms">
      <div class="hero__stats">
        {heroStats.map((s) => (
          <div>
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
      <a class="btn" href={contact.whatsapp} target="_blank" rel="noreferrer">
        💬 Escríbenos por WhatsApp
      </a>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(540px, 90vh, 780px);
    display: grid;
    align-items: end;
    padding-bottom: clamp(36px, 6vw, 68px);
  }

  .hero__media {
    position: absolute;
    inset: 0;
  }

  .hero__media :global(.hero__img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  /* Overlay cálido y luminoso, no oscuro */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(250, 246, 239, 0.92) 0%, rgba(250, 246, 239, 0.55) 42%, rgba(250, 246, 239, 0.15) 70%),
      linear-gradient(0deg, rgba(248, 235, 224, 0.5) 0%, transparent 45%);
  }

  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 16px;
    align-items: start;
    justify-items: start;
  }

  .hero__card {
    max-width: 600px;
    padding: clamp(28px, 4.5vw, 40px);
    border-radius: var(--radius-xl);
    background: rgba(255, 253, 248, 0.88);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: var(--shadow-lg);
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
    padding: 6px 14px;
    border-radius: var(--radius-pill);
    background: var(--hp-peach);
    color: var(--hp-brown);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__title {
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(2.3rem, 5.8vw, 3.5rem);
    font-weight: 600;
    line-height: 1.08;
    color: var(--hp-ink);
  }

  .hero__subtitle {
    margin: 14px 0 0;
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.6vw, 1.5rem);
    font-style: italic;
    font-weight: 500;
    color: var(--hp-brown-soft);
    line-height: 1.35;
  }

  .hero__text {
    margin: 18px 0 0;
    color: var(--hp-muted);
    line-height: 1.75;
    font-size: 1rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .hero__aside {
    display: grid;
    gap: 12px;
    width: 100%;
    max-width: 600px;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    padding: 18px;
    border-radius: var(--radius-lg);
    background: var(--hp-paper);
    border: 1px solid var(--hp-honey);
    box-shadow: var(--shadow-soft);
  }

  .hero__stats strong {
    display: block;
    font-family: var(--font-serif);
    font-size: 1.55rem;
    color: var(--hp-olive-dark);
    line-height: 1;
  }

  .hero__stats span {
    display: block;
    margin-top: 5px;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--hp-muted);
    line-height: 1.3;
  }
</style>
