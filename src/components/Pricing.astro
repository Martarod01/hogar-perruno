---
import { pricing } from "../config/site";
---

<section class="section section--green pricing" id="tarifas" aria-labelledby="pricing-title">
  <div class="container">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">{pricing.eyebrow}</p>
      <h2 id="pricing-title">{pricing.title}</h2>
      <p class="lead">{pricing.lead}</p>
    </div>

    <div class="pricing-grid">
      {pricing.items.map((item, index) => (
        <article
          class={`pricing-card card${item.highlight ? " pricing-card--featured" : ""}`}
          data-reveal
          style={`--reveal-delay: ${index * 100}ms`}
        >
          {item.highlight && <span class="pricing-badge">Más solicitado</span>}
          <div class="pricing-header">
            <h3>{item.name}</h3>
            <div class="pricing-price">
              <span class="price-amount">{item.price}€</span>
              <span class="price-unit">/{item.unit}</span>
            </div>
          </div>
          <p class="pricing-desc">{item.description}</p>
          <a class="button" href="#contacto">
            Reservar
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14m-6-6 6 6-6 6" /></svg>
          </a>
        </article>
      ))}
    </div>

    {pricing.note && (
      <p class="pricing-note" data-reveal>{pricing.note}</p>
    )}
  </div>
</section>

<style>
  .pricing-grid {
    display: grid;
    gap: 24px;
    max-width: 780px;
    margin-inline: auto;
  }

  .pricing-card {
    position: relative;
    padding: 36px 32px;
    display: grid;
    gap: 20px;
  }

  .pricing-card--featured {
    border-color: rgba(90, 122, 82, 0.4);
    background: linear-gradient(145deg, var(--color-white) 0%, rgba(232, 240, 230, 0.35) 100%);
  }

  .pricing-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    padding: 6px 18px;
    border-radius: var(--radius-pill);
    background: linear-gradient(135deg, var(--color-green), var(--color-moss));
    color: var(--color-white);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: var(--shadow-cta);
    white-space: nowrap;
  }

  .pricing-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .pricing-header h3 {
    font-size: clamp(1.2rem, 2vw, 1.45rem);
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    flex-shrink: 0;
  }

  .price-amount {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 700;
    color: var(--color-green-dark);
    line-height: 1;
  }

  .price-unit {
    color: var(--color-graphite);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .pricing-desc {
    color: var(--color-graphite);
    font-size: 0.97rem;
    line-height: 1.7;
    margin: 0;
  }

  .pricing-card .button {
    width: fit-content;
  }

  .pricing-card .button svg {
    width: 17px;
    height: 17px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: transform 240ms var(--ease);
  }

  .pricing-card .button:hover svg {
    transform: translateX(3px);
  }

  .pricing-note {
    margin-top: 36px;
    text-align: center;
    color: var(--color-graphite);
    font-size: 0.92rem;
    padding: 18px 24px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-white);
    max-width: 620px;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
