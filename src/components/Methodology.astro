---
import { methodology } from "../config/site";
---

<section class="section section--soft methodology" id="como-trabajamos" aria-labelledby="methodology-title">
  <div class="container methodology-grid">
    <div class="section-heading section-heading--left" data-reveal>
      <p class="eyebrow">{methodology.eyebrow}</p>
      <h2 id="methodology-title">{methodology.title}</h2>
      <p class="lead">{methodology.lead}</p>
      <a class="button" href="#contacto">{methodology.cta}</a>
    </div>

    <div class="steps">
      {methodology.steps.map((item, index) => (
        <article class="step-card" data-reveal style={`--reveal-delay: ${index * 110}ms`}>
          <span class="step-number">{item.step}</span>
          <div class="step-body">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .methodology-grid {
    display: grid;
    gap: 40px;
    align-items: center;
  }

  .section-heading { margin-bottom: 0; }
  .section-heading .button { margin-top: 28px; }

  .steps {
    position: relative;
    display: grid;
    gap: 18px;
  }

  .steps::before {
    position: absolute;
    top: 44px;
    bottom: 44px;
    left: 51px;
    width: 2px;
    background: linear-gradient(180deg, var(--color-green), rgba(90, 122, 82, 0.12));
    content: "";
  }

  .step-card {
    position: relative;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 20px;
    align-items: center;
    padding: 26px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-white);
    box-shadow: var(--shadow-soft);
    transition: transform 320ms var(--ease), box-shadow 320ms var(--ease);
  }

  .step-card:hover {
    transform: translateX(6px);
    box-shadow: var(--shadow-card);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-green), var(--color-moss));
    color: var(--color-white);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    box-shadow: var(--shadow-cta);
    flex-shrink: 0;
  }

  .step-body h3 { margin-bottom: 8px; }
  .step-body p { color: var(--color-graphite); font-size: 0.96rem; }

  @media (min-width: 900px) {
    .methodology-grid {
      grid-template-columns: minmax(0, 0.85fr) minmax(0, 1fr);
      gap: 64px;
    }
  }
</style>
