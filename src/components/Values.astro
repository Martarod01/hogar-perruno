---
import { values } from "../config/site";

const iconMap = {
  heart: "M24 42S7 32 7 18c0-6 4-10 10-10 3 0 6 2 7 5 1-3 4-5 7-5 6 0 10 4 10 10 0 14-17 24-17 24Z",
  home: "M10 20v-6l14-11 14 11v6M10 20h28v22H10z M19 42V30h10v12",
  camera: "M12 10h-2a3 3 0 0 0-3 3v22a3 3 0 0 0 3 3h24a3 3 0 0 0 3-3V13a3 3 0 0 0-3-3h-2l-3-4H15ZM24 34a7 7 0 1 0 0-14 7 7 0 0 0 0 14Z",
  shield: "M24 4 8 10v16c0 9 16 18 16 18s16-9 16-18V10ZM18 26l5 5 9-11",
  paw: "M12 16a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm24 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM8 28a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm32 0a4 4 0 1 0 0-8 4 4 0 0 0 0 8ZM24 44c6 0 14-4 14-10 0-4-6-10-14-10S10 30 10 34c0 6 8 10 14 10Z",
};

const getIconPath = (icon: string) => iconMap[icon as keyof typeof iconMap] ?? iconMap.paw;
---

<section class="section section--green values" id="valores" aria-labelledby="values-title">
  <div class="container">
    <div class="section-heading" data-reveal>
      <p class="eyebrow">{values.eyebrow}</p>
      <h2 id="values-title">{values.title}</h2>
      <p class="lead">{values.lead}</p>
    </div>

    <div class="values-grid">
      {values.items.map((value, index) => (
        <article class="value-card card" data-reveal style={`--reveal-delay: ${index * 90}ms`}>
          <span class="value-icon">
            <svg viewBox="0 0 48 48" aria-hidden="true">
              <path d={getIconPath(value.icon)} />
            </svg>
          </span>
          <h3>{value.title}</h3>
          <p>{value.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .values-grid {
    display: grid;
    gap: 20px;
  }

  .value-card {
    padding: 30px 28px;
  }

  .value-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-card);
    border-color: rgba(90, 122, 82, 0.3);
  }

  .value-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    margin-bottom: 22px;
    border-radius: 18px;
    background: var(--color-green-soft);
    color: var(--color-green-dark);
  }

  .value-icon svg {
    width: 30px;
    height: 30px;
  }

  .value-card path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 3;
  }

  .value-card h3 { margin-bottom: 12px; }
  .value-card p { color: var(--color-graphite); font-size: 0.96rem; }

  @media (min-width: 680px) {
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1040px) {
    .values-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
